@@ -52,6 +58,9 @@ struct ipe_eval_ctx {
 #ifdef CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG
 	const struct ipe_inode *ipe_inode;
 #endif /* CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG */
+#ifdef CONFIG_IPE_PROP_COMPOSEFS_BACKING_FS_VERITY
+	const struct inode *composefs_metadata_root;
+#endif /* CONFIG_IPE_PROP_COMPOSEFS_BACKING_FS_VERITY */
 };
 
 enum ipe_match {
diff --git a/security/ipe/hooks.c b/security/ipe/hooks.c
index 0ae54a880405..8a4ab95ee337 100644
--- a/security/ipe/hooks.c
+++ b/security/ipe/hooks.c
@@ -312,7 +312,7 @@ int ipe_bdev_setintegrity(struct block_device *bdev, enum lsm_integrity_type typ
 }
 #endif /* CONFIG_IPE_PROP_DM_VERITY */
 
-#ifdef CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG
+#ifdef IPE_HAS_INODE_BLOB
 /**
  * ipe_inode_setintegrity() - save integrity data from a inode to IPE's LSM blob.
  * @inode: The inode to source the security blob from.
@@ -320,8 +320,9 @@ int ipe_bdev_setintegrity(struct block_device *bdev, enum lsm_integrity_type typ
  * @value: The value to be stored.
  * @size: The size of @value.
  *
- * This hook is currently used to save the existence of a validated fs-verity
- * builtin signature into LSM blob.
+ * This hook is currently used to save a verified fs-verity built-in signature
+ * on the inode itself, or the fs-verity digest of the file backing the inode's
+ * filesystem (an EROFS file-backed mount used as composefs metadata).
  *
  * Return: %0 on success. If an error occurs, the function will return the
  * -errno.
@@ -332,11 +333,56 @@ int ipe_inode_setintegrity(const struct inode *inode,
 {
 	struct ipe_inode *inode_sec = ipe_inode(inode);
 
+#ifdef CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG
 	if (type == LSM_INT_FSVERITY_BUILTINSIG_VALID) {
 		inode_sec->fs_verity_signed = size > 0 && value;
 		return 0;
 	}
+#endif
+
+#ifdef CONFIG_IPE_PROP_COMPOSEFS_BACKING_FS_VERITY
+	if (type == LSM_INT_BACKING_FILE_FSVERITY_DIGEST) {
+		const struct backing_file_fsverity_digest *digest = value;
+		struct digest_info *info;
+
+		if (!value)
+			return -EINVAL;
+
+		info = kzalloc_obj(*info);
+		if (!info)
+			return -ENOMEM;
+
+		info->digest = kmemdup(digest->digest, digest->digest_len, GFP_KERNEL);
+		info->alg = kstrdup(digest->alg, GFP_KERNEL);
+		info->digest_len = digest->digest_len;
+		if (!info->digest || !info->alg) {
+			ipe_digest_free(info);
+			return -ENOMEM;
+		}
+
+		ipe_digest_free(inode_sec->composefs_backing_fs_verity_digest);
+		inode_sec->composefs_backing_fs_verity_digest = info;
+		return 0;
+	}
+#endif
 
 	return -EINVAL;
 }
-#endif /* CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG */
+#endif /* IPE_HAS_INODE_BLOB */
+
+#ifdef CONFIG_IPE_PROP_COMPOSEFS_BACKING_FS_VERITY
+/**
+ * ipe_inode_free_security() - free IPE's LSM blob allocations of an inode.
+ * @inode: Supplies a pointer to the inode being freed.
+ *
+ * The composefs backing-file fs-verity digest is held as a separately
+ * allocated digest_info; free it here. The blob memory itself is reclaimed
+ * by the LSM blob framework.
+ */
+void ipe_inode_free_security(struct inode *inode)
+{
+	struct ipe_inode *blob = ipe_inode(inode);
+
+	ipe_digest_free(blob->composefs_backing_fs_verity_digest);
+}
+#endif /* CONFIG_IPE_PROP_COMPOSEFS_BACKING_FS_VERITY */
